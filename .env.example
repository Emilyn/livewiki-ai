# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ── Google OAuth ──────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Redirect URI for Google OAuth (leave blank to auto-detect from RAILWAY_PUBLIC_DOMAIN)
GOOGLE_REDIRECT_URI=
GOOGLE_AUTH_REDIRECT_URI=

# ── GitHub OAuth ──────────────────────────────────────────────────────────────
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# Redirect URI for GitHub OAuth (leave blank to auto-detect from RAILWAY_PUBLIC_DOMAIN)
GITHUB_REDIRECT_URI=

# ── GitLab OAuth ──────────────────────────────────────────────────────────────
GITLAB_CLIENT_ID=
GITLAB_CLIENT_SECRET=
# Redirect URI for GitLab OAuth (leave blank to auto-detect from RAILWAY_PUBLIC_DOMAIN)
GITLAB_REDIRECT_URI=

# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string — used by the Go backend
# For docker-compose: postgres://mdfviewer:mdfviewer@db:5432/mdfviewer?sslmode=disable
DATABASE_URL=postgres://mdfviewer:mdfviewer@localhost:5432/mdfviewer?sslmode=disable

# ── App ───────────────────────────────────────────────────────────────────────
# Email address granted super-admin privileges on first boot
SUPER_ADMIN_EMAIL=

# Directory where uploaded files and app data are stored
# In production (Railway) this is mounted as a persistent volume at /data/uploads
UPLOADS_DIR=./uploads

# Directory where compiled frontend static assets are served from
STATIC_DIR=./static

# Server port (Railway sets this automatically)
PORT=8080

# Set to "release" in production to disable debug output and dev CORS
GIN_MODE=debug

# ── Railway (auto-set by Railway, do not set manually) ───────────────────────
# RAILWAY_PUBLIC_DOMAIN=your-app.up.railway.app
